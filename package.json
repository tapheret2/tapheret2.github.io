{
  "name": "phat-pham-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:css": "npx @tailwindcss/cli -i ./src/input.css -o ./src/output.css --watch",
    "dev:serve": "live-server src --host=127.0.0.1 --port=3000 --open=/index.html",
    "dev": "concurrently \"npm:dev:css\" \"npm:dev:serve\"",
    "build:site": "node ./scripts/build.mjs",
    "build:css": "npx @tailwindcss/cli -i ./src/input.css -o ./out/output.css --minify",
    "build": "npm run build:site && npm run build:css",
    "preview": "npm run build && live-server out --host=127.0.0.1 --port=4173 --open=/index.html"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.14",
    "concurrently": "^9.2.1",
    "live-server": "^1.2.2",
    "tailwindcss": "^4.1.14"
  }
}
